# This file is just a convenience for setting up necessary env vars.
# (and a reminder of which ones need set)
# Obviously, provide your own root user name and password when starting the app.

GEN_DL_ROOT_USER="root"
GEN_DL_ROOT_PASSWORD="password"
GEN_DL_SECRET_KEY="0" # Set this key to something non-trivial
GEN_DL_TOKEN_ACCESS_DELTA="PT30M" # Use ISO 8601 format for time delta/duration (This var is optional to set)